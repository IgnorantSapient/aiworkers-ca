<div class="relative mx-auto w-full max-w-xl animate-float rounded-[2rem] border border-white/15 bg-zinc-950/80 p-4 shadow-premium backdrop-blur-xl">
  <div class="absolute -inset-1 -z-10 rounded-[2rem] bg-gradient-to-br from-white/20 via-zinc-500/10 to-transparent blur-2xl"></div>
  <div class="rounded-[1.5rem] border border-white/10 bg-black/80 p-5">
    <div class="mb-5 flex items-center justify-between border-b border-white/10 pb-4">
      <div>
        <p class="text-xs uppercase tracking-[.28em] text-zinc-500">AI Implementation</p>
        <h3 class="mt-1 text-lg font-bold">90-Day Automation Roadmap</h3>
      </div>
      <div class="rounded-full border border-white/15 px-3 py-1 text-xs text-zinc-300">In progress</div>
    </div>

    <div class="space-y-3">
      {[
        ['01', 'Map repetitive workflows', 'Find the highest-ROI tasks across sales, support, and operations.'],
        ['02', 'Deploy focused AI workers', 'Launch small, measurable automations with human approvals built in.'],
        ['03', 'Scale what performs', 'Track savings, improve prompts, and expand the workflows that prove value.'],
      ].map(([step, title, copy]) => (
        <div class="rounded-2xl border border-white/10 bg-white/[.035] p-4">
          <div class="flex gap-4">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/15 bg-white/[.06] text-sm font-bold text-white">
              {step}
            </div>
            <div>
              <p class="text-sm font-semibold text-white">{title}</p>
              <p class="mt-1 text-xs leading-relaxed text-zinc-500">{copy}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-4 rounded-2xl border border-white/10 bg-white/[.035] p-4">
      <div class="mb-3 flex items-center justify-between text-xs text-zinc-400">
        <span>Projected monthly hours saved</span>
        <span class="font-semibold text-white">120+</span>
      </div>
      <div class="h-2 rounded-full bg-white/10">
        <span class="block h-2 w-4/5 rounded-full bg-gradient-to-r from-zinc-400 to-white"></span>
      </div>
    </div>
  </div>
</div>

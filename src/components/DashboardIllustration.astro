<div class="relative mx-auto w-full max-w-xl animate-float rounded-[2rem] border border-white/15 bg-zinc-950/80 p-4 shadow-premium backdrop-blur-xl">
  <div class="absolute -inset-1 -z-10 rounded-[2rem] bg-gradient-to-br from-white/20 via-zinc-500/10 to-transparent blur-2xl"></div>
  <div class="rounded-[1.5rem] border border-white/10 bg-black/80 p-5">
    <div class="mb-5 flex items-center justify-between border-b border-white/10 pb-4">
      <div><p class="text-xs uppercase tracking-[.28em] text-zinc-500">Digital Workforce</p><h3 class="mt-1 text-lg font-bold">AI Worker Command Center</h3></div>
      <div class="rounded-full border border-white/15 px-3 py-1 text-xs text-zinc-300">Live</div>
    </div>
    <div class="grid gap-3 sm:grid-cols-3">
      {['Support', 'Sales', 'Ops'].map((label, i) => <div class="rounded-2xl border border-white/10 bg-white/[.035] p-4"><div class="mb-8 h-2 rounded bg-white/20"><span class="block h-2 rounded bg-white/70" style={`width:${74 + i * 7}%`}></span></div><p class="text-sm font-semibold">{label} Agent</p><p class="mt-1 text-xs text-zinc-500">{i === 0 ? '312 tickets triaged' : i === 1 ? '48 leads qualified' : '96 tasks completed'}</p></div>)}
    </div>
    <div class="mt-4 grid gap-3 md:grid-cols-[1.2fr_.8fr]">
      <div class="rounded-2xl border border-white/10 bg-white/[.035] p-4">
        <div class="flex items-end gap-2 h-28" aria-label="Workflow automation chart">
          {[35,58,46,72,64,88,78,96].map((h) => <span class="w-full rounded-t bg-gradient-to-t from-zinc-700 to-white/80" style={`height:${h}%`}></span>)}
        </div>
        <p class="mt-3 text-xs text-zinc-500">Automation throughput this week</p>
      </div>
      <div class="rounded-2xl border border-white/10 bg-white/[.035] p-4">
        {['Inbox → Triage', 'CRM → Follow-up', 'Docs → Summary'].map((flow) => <div class="mb-3 flex items-center gap-3 last:mb-0"><span class="h-2 w-2 rounded-full bg-white"></span><span class="text-xs text-zinc-300">{flow}</span></div>)}
      </div>
    </div>
  </div>
</div>

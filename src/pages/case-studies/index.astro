---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
const cases = await getCollection('case-studies');
---
<BaseLayout title="AI Automation Case Studies | aiworkers.ca" canonical="https://aiworkers.ca/case-studies/">
  <Header /><main class="min-h-screen bg-black px-5 py-32 lg:px-8"><div class="mx-auto max-w-5xl"><p class="text-sm uppercase tracking-[.32em] text-zinc-500">Case Studies</p><h1 class="mt-4 font-display text-5xl font-black tracking-tight">Digital workforce results</h1><div class="mt-12 grid gap-5 md:grid-cols-2">{cases.map((item)=><a href={`/case-studies/${item.slug}/`} class="rounded-3xl border border-white/10 bg-white/[.035] p-6 transition hover:bg-white/[.07]"><p class="text-sm text-zinc-500">{item.data.industry}</p><h2 class="mt-2 text-2xl font-black">{item.data.title}</h2><p class="mt-3 text-zinc-400">{item.data.description}</p><p class="mt-5 font-bold">{item.data.result}</p></a>)}</div></div></main>
</BaseLayout>

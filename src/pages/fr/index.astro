---
import BaseLayout from '../../layouts/BaseLayout.astro';
import LandingPage from '../../components/LandingPage.astro';
import { locales } from '../../i18n';

const content = locales['fr-CA'];
---
<BaseLayout
  title={content.title}
  description={content.description}
  canonical="https://aiworkers.ca/fr/"
  lang={content.code}
  alternateLocales={[
    { lang: 'fr-CA', href: 'https://aiworkers.ca/fr/' },
    { lang: 'en-CA', href: 'https://aiworkers.ca/' },
    { lang: 'x-default', href: 'https://aiworkers.ca/' },
  ]}
  ogImageAlt={content.ogAlt}
  serviceType={content.serviceType}
>
  <LandingPage content={content} />
</BaseLayout>

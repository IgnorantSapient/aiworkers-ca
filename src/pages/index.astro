---
import BaseLayout from '../layouts/BaseLayout.astro';
import ParticleCanvas from '../components/ParticleCanvas.astro';
import Header from '../components/Header.astro';
import DashboardIllustration from '../components/DashboardIllustration.astro';

const aiWorkers = [
  ['▣','AI RFP / Proposal Response Agent','Drafts compliant, buyer-specific proposal responses using your past wins, documents, and pricing logic.','Submit stronger proposals in less time.'],
  ['◈','AI Contract Review Assistant','Flags risky clauses, missing terms, renewal obligations, and approval bottlenecks before contracts stall.','Reduce legal review cycles and risk.'],
  ['◎','AI Due Diligence Analyst','Synthesizes financial, operational, market, and vendor information into decision-ready diligence briefs.','Accelerate decisions with less analyst time.'],
  ['▤','AI Financial Reporting Analyst','Prepares KPI summaries, variance explanations, management packs, and recurring finance narratives.','Turn raw reporting into executive insight.'],
  ['$','AI Accounts Receivable Collection Agent','Monitors invoices, sends polite follow-ups, updates CRM notes, and escalates overdue accounts.','Improve cash flow without extra headcount.'],
  ['⌕','AI Enterprise Search / Knowledge Agent','Lets teams ask natural-language questions across policies, SOPs, documents, tickets, and internal knowledge.','Find answers instantly across the business.'],
  ['↗','AI Customer Success Expansion Agent','Identifies expansion signals, churn risks, renewal moments, and account follow-up opportunities.','Grow accounts with proactive outreach.'],
  ['◇','AI Vendor Risk Management Agent','Tracks vendors, compliance documents, security questionnaires, renewals, and risk changes.','Control vendor exposure at scale.'],
  ['⚿','AI Cybersecurity Triage Agent','Classifies alerts, enriches incidents, drafts tickets, and routes security events to the right owner.','Respond faster to security signals.'],
  ['◷','AI Regulatory Change Monitor','Watches regulatory updates, summarizes business impact, and alerts teams to required policy changes.','Stay ahead of compliance changes.']
];
const industries = ['Manufacturing','Healthcare','Legal','Recruiting','Real Estate','Logistics','Finance','Agencies'];
---
<BaseLayout>
  <ParticleCanvas />
  <Header />
  <main class="relative z-10">
    <section class="mono-gradient relative overflow-hidden px-5 pb-20 pt-32 lg:px-8 lg:pb-28 lg:pt-44">
      <div class="absolute inset-0 grid-bg opacity-70"></div>
      <div class="mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-[1.02fr_.98fr]">
        <div class="reveal relative">
          <div class="mb-6 inline-flex items-center gap-3 rounded-full border border-white/15 bg-white/[.04] px-4 py-2 text-sm text-zinc-300 backdrop-blur-xl"><span class="h-2 w-2 rounded-full bg-white animate-pulseSoft"></span> Canadian AI automation company</div>
          <p class="mb-3 text-sm font-semibold uppercase tracking-[.35em] text-zinc-500">aiworkers.ca</p>
          <h1 class="font-monoHeadline text-balance text-5xl font-extrabold tracking-[-.065em] text-white sm:text-6xl lg:text-8xl">Hire AI Workers for Your Business</h1>
          <p class="mt-7 max-w-2xl text-xl leading-8 text-zinc-300">No burnout, no distractions, no inconsistencies — just dependable execution. AI employees that work 24/7.</p>
          <div class="mt-9 flex flex-col gap-4 sm:flex-row">
            <a href="#consultation" class="button-shine rounded-full bg-white px-7 py-4 text-center font-extrabold text-black transition hover:-translate-y-1 hover:bg-zinc-200">Hire My First AI Worker</a>
            <a href="#services" class="rounded-full border border-white/20 px-7 py-4 text-center font-bold text-white transition hover:-translate-y-1 hover:bg-white/10">Explore AI Workers</a>
          </div>
          <div class="mt-10 grid gap-3 sm:grid-cols-3">
            {['Zero sick days','Never stops working','10x faster onboarding'].map((stat) => <div class="glass rounded-2xl p-4 transition hover:-translate-y-1"><p class="text-2xl font-black tracking-tight">{stat.split(' ')[0]}</p><p class="mt-1 text-sm text-zinc-400">{stat.replace(stat.split(' ')[0] + ' ', '')}</p></div>)}
          </div>
        </div>
        <div class="reveal"><DashboardIllustration /></div>
      </div>
    </section>



    <section id="services" class="bg-[#070707] px-5 py-24 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="reveal mx-auto max-w-3xl text-center"><p class="text-sm uppercase tracking-[.32em] text-zinc-500">Services</p><h2 class="mt-4 font-display text-4xl font-black tracking-tight lg:text-6xl">AI Workers for high-friction business workflows</h2><p class="mt-5 text-lg text-zinc-400">Deploy digital employees across proposals, finance, customer success, compliance, risk, security, and knowledge operations.</p></div>
        <div class="mt-14 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
          {aiWorkers.map(([icon,title,desc,outcome]) => <article class="reveal group rounded-3xl border border-white/10 bg-gradient-to-b from-white/[.07] to-white/[.025] p-6 transition duration-300 hover:-translate-y-2 hover:border-white/25 hover:bg-white/[.08]"><div class="mb-6 grid h-12 w-12 place-items-center rounded-2xl border border-white/15 bg-black text-xl font-black text-white transition group-hover:scale-110">{icon}</div><h3 class="text-xl font-extrabold tracking-tight">{title}</h3><p class="mt-3 text-sm leading-6 text-zinc-400">{desc}</p><div class="mt-6 rounded-2xl border border-white/10 bg-black/45 p-4 text-sm font-semibold text-zinc-200">Outcome: {outcome}</div></article>)}
        </div>
      </div>
    </section>

    <section id="process" class="border-y border-white/10 bg-black px-5 py-24 lg:px-8">
      <div class="mx-auto max-w-7xl"><div class="reveal max-w-3xl"><p class="text-sm uppercase tracking-[.32em] text-zinc-500">How it works</p><h2 class="mt-4 font-display text-4xl font-black tracking-tight lg:text-6xl">From workflow analysis to deployed AI workers</h2></div>
        <div class="mt-14 grid gap-6 lg:grid-cols-3">
          {['We Analyze Your Workflow','We Deploy AI Workers','You Scale Without Hiring'].map((step,i) => <div class="reveal relative rounded-3xl border border-white/10 bg-zinc-950 p-8"><div class="mb-10 flex items-center justify-between"><span class="text-6xl font-black text-white/10">0{i+1}</span><span class="h-px flex-1 bg-white/10 mx-5"></span><span class="h-3 w-3 rounded-full bg-white"></span></div><h3 class="text-2xl font-black">{step}</h3><p class="mt-4 text-zinc-400">{i===0?'We map repetitive tasks, data sources, approvals, and ROI potential.':i===1?'We configure AI agents, connect systems, define guardrails, and launch controlled workflows.':'Your team moves faster while AI Workers handle repeatable execution around the clock.'}</p></div>)}
        </div>
      </div>
    </section>

    <section id="roi" class="bg-[#070707] px-5 py-24 lg:px-8">
      <div class="mx-auto grid max-w-7xl gap-12 lg:grid-cols-[.9fr_1.1fr] lg:items-center">
        <div class="reveal"><p class="text-sm uppercase tracking-[.32em] text-zinc-500">ROI</p><h2 class="mt-4 font-display text-4xl font-black tracking-tight lg:text-6xl">Measure AI by business outcomes</h2><p class="mt-5 text-lg text-zinc-400">Every AI Worker is designed around a measurable operational result: reduced cost, faster response, better conversion, or fewer repetitive tasks.</p></div>
        <div class="grid gap-5 sm:grid-cols-2">
          {['Reduced operational costs by upto','Faster response times by upto','Improved lead conversion by upto','Less repetitive work by upto'].map((label,i) => <div class="reveal glass rounded-3xl p-6"><p class="text-sm text-zinc-500">{label}</p><p class="mt-4 text-5xl font-black tracking-tight">{['95%','82%','3.1x','70%'][i]}</p><div class="mt-6 h-3 rounded bg-white/10"><span class="block h-3 rounded bg-gradient-to-r from-zinc-600 to-white" style={`width:${[95,82,74,70][i]}%`}></span></div></div>)}
        </div>
      </div>
    </section>

    <section id="industries" class="border-y border-white/10 bg-black px-5 py-24 lg:px-8">
      <div class="mx-auto max-w-7xl"><div class="reveal mx-auto max-w-3xl text-center"><p class="text-sm uppercase tracking-[.32em] text-zinc-500">Industries</p><h2 class="mt-4 font-display text-4xl font-black tracking-tight lg:text-6xl">Built for teams drowning in repetitive work</h2></div>
        <div class="mt-14 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">{industries.map((industry,i) => <div class="reveal rounded-3xl border border-white/10 bg-white/[.035] p-6 transition hover:-translate-y-1 hover:bg-white/[.07]"><div class="mb-8 text-3xl">{['▥','✚','§','◉','⌂','⇄','◫','✦'][i]}</div><h3 class="text-xl font-black">{industry}</h3><p class="mt-3 text-sm text-zinc-500">Workflow automation for teams where responsiveness and consistency drive revenue.</p></div>)}</div>
      </div>
    </section>

    <section id="about" class="bg-[#070707] px-5 py-24 lg:px-8"><div class="reveal mx-auto max-w-5xl rounded-[2rem] border border-white/10 bg-gradient-to-br from-white/[.08] to-white/[.025] p-8 text-center shadow-premium lg:p-16"><p class="text-sm uppercase tracking-[.32em] text-zinc-500">About aiworkers.ca</p><h2 class="mt-4 font-display text-4xl font-black tracking-tight lg:text-6xl">Built with love and care in Waterloo, Ontario</h2><p class="mx-auto mt-6 max-w-3xl text-xl leading-8 text-zinc-300">AI Workers is crafted by a Canadian team focused on helping businesses scale with practical, dependable AI automation built close to home.</p></div></section>

    <section id="consultation" class="relative overflow-hidden px-5 py-24 lg:px-8"><div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(255,255,255,.22),transparent_36%),linear-gradient(135deg,#050505,#171717,#050505)]"></div><div class="reveal relative mx-auto max-w-4xl text-center"><h2 class="font-display text-5xl font-black tracking-[-.04em] lg:text-7xl">Build Your AI Workforce</h2><p class="mx-auto mt-6 max-w-2xl text-lg text-zinc-300">Start with one high-value workflow. Prove the ROI. Then scale AI Workers across your business.</p><a href="mailto:hello@aiworkers.ca?subject=Schedule%20AI%20Worker%20Consultation" class="button-shine mt-9 inline-flex rounded-full bg-white px-8 py-4 font-extrabold text-black transition hover:-translate-y-1 hover:bg-zinc-200">Schedule Consultation</a></div></section>
  </main>
  <footer class="relative z-10 border-t border-white/10 bg-black px-5 py-12 lg:px-8"><div class="mx-auto flex max-w-7xl flex-col gap-8 md:flex-row md:items-center md:justify-between"><div><p class="font-display text-xl font-black">aiworkers.ca</p><p class="mt-2 text-sm text-zinc-500">Canadian AI automation and digital workforce consulting.</p></div><div class="flex flex-wrap gap-5 text-sm text-zinc-400"><a href="#services">Services</a><a href="#process">Process</a><a href="/blog/">Blog</a><a href="/case-studies/">Case Studies</a><a href="mailto:hello@aiworkers.ca">hello@aiworkers.ca</a><a href="https://www.linkedin.com/company/aiworkers-ca" aria-label="LinkedIn">in</a><a href="https://x.com/aiworkersca" aria-label="X">𝕏</a></div><p class="text-sm text-zinc-600">© {new Date().getFullYear()} Neon Nano Labs</p></div></footer>
</BaseLayout>
